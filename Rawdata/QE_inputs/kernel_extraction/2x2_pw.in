&CONTROL
  calculation = "scf",
  pseudo_dir  = "../../../../pseudo",
  prefix      = "solute",
  outdir      = "./solute",
  tprnfor     = .true.,
  tefield     = .true.,
  dipfield    = .true.
/
&SYSTEM
tot_charge = 0.0
  ibrav       = 0,
  nat         = 64,
  ntyp        = 1,
  ecutwfc     = 70.0,
